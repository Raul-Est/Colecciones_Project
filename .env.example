# Copiar este fichero como .env y rellenar los valores reales
# Nunca commitear el fichero .env

# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=cambiar-por-una-clave-segura-generada

# Base de datos (solo necesario en producción)
DB_NAME=colecciones_db
DB_USER=colecciones_user
DB_PASSWORD=cambiar-por-password-seguro
DB_HOST=localhost
DB_PORT=5432

# Hosts permitidos (solo necesario en producción, separados por coma)
ALLOWED_HOSTS=tudominio.com,www.tudominio.com
